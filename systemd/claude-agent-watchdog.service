# Watchdog: re-runs the idempotent start script; if the tmux session died
# (claude crash, OOM kill), this brings the agent back within ~2 minutes.
# Paired with claude-agent-watchdog.timer.

[Unit]
Description=Claude Telegram agent watchdog (restart if dead)

[Service]
Type=oneshot
User=YOUR_USER
Environment=HOME=/home/YOUR_USER
WorkingDirectory=/home/YOUR_USER
ExecStart=/bin/sh /home/YOUR_USER/agent-os/bin/start-agent.sh
