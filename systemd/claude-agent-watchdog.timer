# Install:
#   sudo cp ~/agent-os/systemd/claude-agent-watchdog.{service,timer} /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now claude-agent-watchdog.timer

[Unit]
Description=Run the Claude agent watchdog every 2 minutes

[Timer]
OnBootSec=3min
OnUnitActiveSec=2min
Unit=claude-agent-watchdog.service

[Install]
WantedBy=timers.target
